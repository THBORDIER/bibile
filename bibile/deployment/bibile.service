[Unit]
Description=Bibile - Extracteur d'enlevements Hillebrand
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/bibile
Environment="PATH=/usr/bin"
ExecStart=/usr/bin/python3 /opt/bibile/server.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
